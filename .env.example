# Microsoft Entra ID tenant ID (found in Entra ID → Overview)
TENANT_ID=your-entra-tenant-id

# SAML Entity ID — must match the Identifier (Entity ID) configured in the Enterprise Application
ENTITY_ID=https://yourdomain.onmicrosoft.com/cavalry-dev-tools

# Assertion Consumer Service URL — must match the Reply URL in the Enterprise Application
ACS_URL=http://localhost:3002/auth/saml/callback

# SAML signing certificate — base64-encoded DER certificate from the Enterprise Application
# Entra ID portal: Enterprise Applications → cavalry-dev-tools → Single sign-on → SAML Signing Certificate → Download (Certificate Base64)
# Remove the PEM header/footer lines and paste the raw base64 string here
IDP_CERT=base64-encoded-certificate-from-entra-id

# Express session secret — use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-secret

# Port this app listens on
PORT=3002
